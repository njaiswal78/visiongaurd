# Cloudflare Workers AI - Get these from https://dash.cloudflare.com/
# Account ID: Cloudflare Dashboard -> Workers & Pages -> Overview (right sidebar)
# API Token: My Profile -> API Tokens -> Create Token (Workers AI:Edit)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_AUTH_TOKEN=your_api_token

# RTSP Camera
RTSP_URL=rtsp://192.168.1.100:554/stream1
RTSP_USERNAME=admin
RTSP_PASSWORD=your_password

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_USERNAME=your_telegram_username

# Optional: AI Gateway for analytics, caching, rate limiting
CLOUDFLARE_AI_GATEWAY_ID=your_gateway_name
CLOUDFLARE_AI_GATEWAY_AUTH_TOKEN=your_gateway_auth_token

# Debug: set to 1 to log API calls
LOG_CALLS=0

# Optional: customize AI context (Hindi). Example: "Ye camera pehli maali ke kone par hai. View road par hai."
# CAMERA_CONTEXT=...
# Optional: bot display name
# BOT_NAME=ghar ka camera

# Local YOLOv8 (no API cost). Remove or set to 0 to use Cloudflare DETR.
USE_YOLO=1
YOLO_MODEL=yolov8m.pt

# Real-time monitoring: detect every small movement
MOVEMENT_CHECK_SECONDS=2
ALERT_COOLDOWN_SECONDS=10
# Sensitivity: lower = more sensitive (threshold 6-10, diff_pixel 10-15 for small movements)
MOVEMENT_THRESHOLD=8.0
MOVEMENT_DIFF_PIXEL=15
MOVEMENT_BLUR_SIZE=13
